# 生产环境配置
# 静态资源目录
VITE_PUBLIC_PATH=/web/ims/
# 路由前缀
VITE_BASE_URL=
# 是否使用hash路由（生产环境避免服务端路由重写依赖）
VITE_USE_HASH=true
# map文件
VITE_DEVTOOL=none

# 请求地址前缀
VITE_REQUEST_PREFIX=/public/ims/

# 主服务代理地址（生产环境由Nginx代理，此处留空）
VITE_HTTP_PROXY_TARGET=

# 流程服务代理地址（生产环境由Nginx代理，此处留空）
VITE_FLOW_PROXY_TARGET=
# 客户端配置（新增）
# 客户端AppId
VITE_APP_ID=pc

# 客户端AppSecret（可选，启用客户端验证时需要）
# 注意：生产环境建议使用更安全的方式管理密钥，不要直接写在这里
VITE_APP_SECRET=forage_pc123
