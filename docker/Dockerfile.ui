# ============================================
# Forge Admin UI 前端 Dockerfile
# ============================================
# 构建上下文为项目根目录，docker compose 中 context 设为 ..
# Vite 7 要求 Node 20.19+ 或 22.12+；18 会触发 oxc-parser 等 native 绑定问题
FROM node:22-alpine AS builder
WORKDIR /app
COPY forge-admin-ui/package.json forge-admin-ui/pnpm-lock.yaml ./
# lockfile 为 9.x，需与本地一致使用 pnpm 9+（pnpm@8 会报 LOCKFILE_BREAKING_CHANGE）
RUN npm install -g pnpm@9 && pnpm install --frozen-lockfile
COPY forge-admin-ui/ .
RUN pnpm build

FROM nginx:1.25-alpine
COPY --from=builder /app/dist /usr/share/nginx/html/forge
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
