# ============================================
# Forge Admin Docker 环境变量配置
# ============================================
# 复制此文件为 .env 并修改相应配置
# ============================================

# MySQL（外部自建，Compose 不包含数据库容器）
# 本机 MySQL（Docker Desktop）：MYSQL_HOST 可用 host.docker.internal
# Linux 或未启用 host.docker.internal 时：填宿主机局域网 IP / 云上数据库地址
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DB=forge_admin
MYSQL_USER=root
MYSQL_PASSWORD=forge123456

# Redis 配置
REDIS_PASSWORD=forge123456
REDIS_PORT=6379

# 后端服务端口
ADMIN_PORT=8580
FLOW_PORT=8081

# Nginx 端口
NGINX_PORT=80
